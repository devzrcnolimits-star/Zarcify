local function sliderRow(parent, text, minV, maxV, defV, decimals, order, callback)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, 42)
    row.BackgroundColor3 = C.Surface
    row.BorderSizePixel  = 0
    row.LayoutOrder      = order
    row.Parent           = parent
    crn(row, 3)
    str(row, C.Border, 1)
    pad(row, 6, 10, 6, 10)

    local fmt = decimals > 0 and ("%." .. decimals .. "f") or "%d"

    local nameL = lbl(row, text, 11, C.TextDim)
    nameL.Size = UDim2.new(0.6, 0, 0, 14)

    local valL = lbl(row, string.format(fmt, defV), 11, C.TextMain, Enum.TextXAlignment.Right)
    valL.Size = UDim2.new(0.4, 0, 0, 14)

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(1, 0, 0, 5)
    track.Position         = UDim2.new(0, 0, 1, -12)
    track.BackgroundColor3 = C.Border
    track.BorderSizePixel  = 0
    track.Parent           = row
    crn(track, 2)

    local rel0 = (defV - minV) / (maxV - minV)

    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new(rel0, 0, 1, 0)
    fill.BackgroundColor3 = C.Yellow
    fill.BorderSizePixel  = 0
    fill.Parent           = track
    crn(fill, 2)

    local handle = Instance.new("TextButton")
    handle.Size             = UDim2.new(0, 14, 0, 14)
    handle.Position         = UDim2.new(rel0, -7, 0.5, -7)
    handle.BackgroundColor3 = Color3.new(1, 1, 1)
    handle.Text             = ""
    handle.BorderSizePixel  = 0
    handle.AutoButtonColor  = false
    handle.Parent           = track
    crn(handle, 7)

    local dragging = false
    handle.MouseButton1Down:Connect(function() dragging = true end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = math.clamp(
                (i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X,
                0, 1
            )
            local val
            if decimals > 0 then
                val = math.floor((minV + rel * (maxV - minV)) * (10 ^ decimals)) / (10 ^ decimals)
            else
                val = math.floor(minV + rel * (maxV - minV))
            end
            fill.Size       = UDim2.new(rel, 0, 1, 0)
            handle.Position = UDim2.new(rel, -7, 0.5, -7)
            valL.Text       = string.format(fmt, val)
            callback(val)
        end
    end)
end

