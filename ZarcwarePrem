        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP then
                local l = Drawing.new("Line")
                l.Thickness = 1; l.Color = ST.HLColor; l.Visible = false; l.ZIndex = 4
                ST.TracerLines[p] = l
            end
        end
    end)
    ST.TracerConn = RunService.RenderStepped:Connect(function()
        local cam = workspace.CurrentCamera
        local vp = cam.ViewportSize
        local org = Vector2.new(vp.X / 2, vp.Y)
        for pl, l in pairs(ST.TracerLines) do
            pcall(function()
                local ch = pl.Character
                local rt = ch and ch:FindFirstChild("HumanoidRootPart")
                local hm = ch and ch:FindFirstChildOfClass("Humanoid")
                if not rt or not hm or hm.Health <= 0 then l.Visible = false; return end
                local v, on = cam:WorldToViewportPoint(rt.Position)
