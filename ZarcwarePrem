-- │          SPEED ENGINE           │
-- └─────────────────────────────────┘
local function applySpeed()
    local char = LP.Character; if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end
    if ST.SpeedOn then
        hum.WalkSpeed = 16; hum.JumpPower = ST.JumpPower
        local ex = hrp:FindFirstChild("_ZS"); if ex then ex:Destroy() end
        local bv = Instance.new("BodyVelocity")
        bv.Name="_ZS"; bv.MaxForce=Vector3.new(1e4,0,1e4); bv.Velocity=Vector3.zero; bv.Parent=hrp
        if ST.SpeedConn then ST.SpeedConn:Disconnect() end
        ST.SpeedConn = RunService.Heartbeat:Connect(function()
            if not ST.SpeedOn then return end
            local c2=LP.Character; if not c2 then return end
            local h2=c2:FindFirstChildOfClass("Humanoid")
            local r2=c2:FindFirstChild("HumanoidRootPart")
            local b2=r2 and r2:FindFirstChild("_ZS")
            if not h2 or not r2 or not b2 then return end
            local md = h2.MoveDirection
            b2.Velocity = md.Magnitude > 0 and md * (ST.WalkSpeed - 16) or Vector3.zero
            h2.WalkSpeed = 16
        end)
    else
        if ST.SpeedConn then ST.SpeedConn:Disconnect(); ST.SpeedConn=nil end
        local ex=hrp:FindFirstChild("_ZS"); if ex then ex:Destroy() end
        hum.WalkSpeed=16; hum.JumpPower=50
    end
end

