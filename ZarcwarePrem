-- └─────────────────────────────────┘
local function silentFind()
    local cam = workspace.CurrentCamera
    local mp  = UIS:GetMouseLocation()
    local sa  = ST.SA
    local best, bd = nil, sa.FOVAmt
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        local ch = p.Character
        if not ch then continue end
        local pt = ch:FindFirstChild(sa.Part) or ch:FindFirstChild("HumanoidRootPart")
        local hm = ch:FindFirstChildOfClass("Humanoid")
        if not pt or not hm then continue end
        if sa.AliveChk and hm.Health<=0 then continue end
        if sa.TeamChk  and p.Team==LP.Team then continue end
        local v, on = cam:WorldToViewportPoint(pt.Position)
        if not on then continue end
        local d = (Vector2.new(mp.X,mp.Y) - Vector2.new(v.X,v.Y)).Magnitude
        if not sa.CheckFOV or d < bd then bd=d; best=pt end
    end
    return best
end

local function startSilent()
    if ST.SilentHooked then return end
    local ok, mt = pcall(getrawmetatable, game)
    if not ok then return end
    local oldNC = mt.__namecall
    ST.SilentOrig = oldNC
    if not pcall(setreadonly, mt, false) then return end
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if ST.SilentOn then
            if method == "Raycast" and self == workspace then
                local target = silentFind()
                if target then
                    local args = {...}
                    if typeof(args[1]) == "Vector3" then
                        args[2] = target.Position - args[1]
                        return oldNC(self, table.unpack(args))
                    end
                end
            elseif (method=="FindPartOnRayWithWhitelist" or method=="FindPartOnRay") and self==workspace then
                local target = silentFind()
                if target then
                    local args = {...}
                    if typeof(args[1]) == "Ray" then
                        args[1] = Ray.new(args[1].Origin, target.Position - args[1].Origin)
                        return oldNC(self, table.unpack(args))
                    end
                end
            end
        end
        return oldNC(self, ...)
    end)
    pcall(setreadonly, mt, true)
    ST.SilentHooked = true
end

local function stopSilent()
    if not ST.SilentHooked then return end
    local ok, mt = pcall(getrawmetatable, game)
    if ok then
        pcall(setreadonly, mt, false)
        mt.__namecall = ST.SilentOrig
        pcall(setreadonly, mt, true)
    end
    ST.SilentHooked = false; ST.SilentOrig = nil
end

-- ┌─────────────────────────────────┐
-- │        TRIGGERBOT ENGINE        │
-- └─────────────────────────────────┘
local function startTrigger()
    ST.TrigConn = RunService.Heartbeat:Connect(function()
        if not ST.TrigOn then return end
        pcall(function()
            local cam = workspace.CurrentCamera
            local mp  = UIS:GetMouseLocation()
            local ray = cam:ScreenPointToRay(mp.X, mp.Y)
            local rp  = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances = {LP.Character or workspace}
            local res = workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
            if res and res.Instance then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LP and p.Character and res.Instance:IsDescendantOf(p.Character) then
                        local hm = p.Character:FindFirstChildOfClass("Humanoid")
                        if hm and hm.Health > 0 then
                            task.wait(ST.TrigDelay)
                            if mouse1press  then pcall(mouse1press)  end
                            task.wait(0.05)
                            if mouse1release then pcall(mouse1release) end
                        end
                    end
                end
            end
        end)
    end)
end

local function stopTrigger()
    if ST.TrigConn then ST.TrigConn:Disconnect(); ST.TrigConn=nil end
end

-- ┌─────────────────────────────────┐
-- │          MISC ENGINE            │
-- └─────────────────────────────────┘
local function refreshMisc()
    local need = ST.NoSpread or ST.NoRecoil or ST.RapidFire or ST.Wallbang
    if need and not ST.MiscHooked then
        local ok, mt = pcall(getrawmetatable, game)
        if not ok then return end
        local oldNC = mt.__namecall; ST.MiscOrig = oldNC
        if not pcall(setreadonly, mt, false) then return end
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "Raycast" and self == workspace then
                local args = {...}
                if ST.NoSpread and typeof(args[2])=="Vector3" then
                    local d=args[2]; args[2]=d.Unit*d.Magnitude
                end
                if ST.NoRecoil and typeof(args[2])=="Vector3" then
                    local d=args[2]; args[2]=Vector3.new(d.X, math.clamp(d.Y,-0.01,0.01), d.Z)
                end
                if ST.Wallbang and typeof(args[3])=="RaycastParams" then
                    local rp=RaycastParams.new()
                    rp.FilterType=Enum.RaycastFilterType.Exclude
                    rp.FilterDescendantsInstances={}
                    args[3]=rp
                end
                return oldNC(self, table.unpack(args))
            end
            if ST.RapidFire and (method=="FireServer" or method=="InvokeServer") then
                oldNC(self, ...)
                task.delay(0.01, function() pcall(oldNC, self, ...) end)
            end
            return oldNC(self, ...)
        end)
        pcall(setreadonly, mt, true)
        ST.MiscHooked = true
    elseif not need and ST.MiscHooked then
        local ok, mt = pcall(getrawmetatable, game)
        if ok then
            pcall(setreadonly, mt, false)
            mt.__namecall = ST.MiscOrig
            pcall(setreadonly, mt, true)
        end
        ST.MiscHooked = false; ST.MiscOrig = nil
    end
end

