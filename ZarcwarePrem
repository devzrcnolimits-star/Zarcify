local function applyHL(player)
    if not player or not player.Character then return end
    local ex = ST.Highlights[player]
    if ex then pcall(function() ex:Destroy() end) end
    pcall(function()
        local h = Instance.new("Highlight")
        h.FillColor           = ST.HLColor
        h.OutlineColor        = ST.HLColor
        h.FillTransparency    = (not ST.HLFill or ST.HLOutline) and 1 or ST.HLTrans
        h.OutlineTransparency = 0
        h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
        h.Adornee             = player.Character
        h.Parent              = player.Character
        ST.Highlights[player] = h
        player.CharacterAdded:Connect(function(char)
            task.wait(0.1)
            if ST.Highlights[player] then
                pcall(function()
                    local h2 = Instance.new("Highlight")
                    h2.FillColor=h.FillColor; h2.OutlineColor=h.OutlineColor
                    h2.FillTransparency=h.FillTransparency; h2.OutlineTransparency=0
                    h2.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                    h2.Adornee=char; h2.Parent=char
                    ST.Highlights[player]=h2
                end)
            end
        end)
    end)
end

local function removeHL(player)
    local h = ST.Highlights[player]
    if h then pcall(function() h:Destroy() end); ST.Highlights[player] = nil end
end

local function hlAll()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then applyHL(p) end
    end
end

local function clearHL()
    for p in pairs(ST.Highlights) do removeHL(p) end
end

-- Box ESP
local function startBox()
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP then
                local ln = {}
                for i = 1, 4 do
                    local l = Drawing.new("Line")
                    l.Thickness = 1.5; l.Color = ST.HLColor; l.Visible = false; l.ZIndex = 5
                    ln[i] = l
                end
                ST.BoxLines[p] = ln
            end
        end
    end)
    ST.BoxConn = RunService.RenderStepped:Connect(function()
        local cam = workspace.CurrentCamera
        for pl, ln in pairs(ST.BoxLines) do
            pcall(function()
                local ch = pl.Character
                local rt = ch and ch:FindFirstChild("HumanoidRootPart")
                local hm = ch and ch:FindFirstChildOfClass("Humanoid")
                if not rt or not hm or hm.Health <= 0 then
                    for i = 1, 4 do ln[i].Visible = false end
                    return
                end
                local cf = rt.CFrame; local w, h = 2.2, 5.5
                local c3 = {
                    cf * Vector3.new(-w,-h/2,0), cf * Vector3.new(w,-h/2,0),
                    cf * Vector3.new(w,h,0),     cf * Vector3.new(-w,h,0)
                }
                local pts = {}; local ok = true
                for _, c in ipairs(c3) do
                    local v, on = cam:WorldToViewportPoint(c)
                    if not on then ok = false end
                    table.insert(pts, Vector2.new(v.X, v.Y))
                end
                if ok then
                    for i = 1, 4 do
                        ln[i].From    = pts[i]
                        ln[i].To      = pts[i % 4 + 1]
                        ln[i].Color   = ST.HLColor
                        ln[i].Visible = true
                    end
                else
                    for i = 1, 4 do ln[i].Visible = false end
                end
            end)
        end
    end)
end

local function stopBox()
    if ST.BoxConn then ST.BoxConn:Disconnect(); ST.BoxConn = nil end
    for _, ln in pairs(ST.BoxLines) do
        for _, l in ipairs(ln) do pcall(function() l.Visible=false; l:Remove() end) end
    end
    ST.BoxLines = {}
end

-- Tracers
local function startTracers()
