local logOrd = 0
local function Log(msg)
    logOrd = logOrd + 1
    local line = Instance.new("TextLabel")
    line.Size=UDim2.new(1,0,0,13); line.BackgroundTransparency=1
    line.Text="> " .. tostring(msg)
    line.TextColor3=Color3.fromRGB(63,185,80); line.TextSize=10; line.Font=C.Font
    line.TextXAlignment=Enum.TextXAlignment.Left; line.LayoutOrder=logOrd; line.Parent=ConScr
    task.defer(function() ConScr.CanvasPosition=Vector2.new(0,math.huge) end)
end

