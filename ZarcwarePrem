local function aimbotFind()
    local cam = workspace.CurrentCamera
    local mp  = UIS:GetMouseLocation()
    local ab  = ST.AB
    local best, bd = nil, ab.FOVAmt
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        local ch = p.Character
        if not ch then continue end
        local pt = ch:FindFirstChild(ab.Part) or ch:FindFirstChild("HumanoidRootPart")
        local hm = ch:FindFirstChildOfClass("Humanoid")
        if not pt or not hm then continue end
        if ab.AliveChk and hm.Health <= 0 then continue end
        if ab.TeamChk  and p.Team == LP.Team then continue end
        local v, on = cam:WorldToViewportPoint(pt.Position)
        if not on then continue end
        local d = (Vector2.new(mp.X, mp.Y) - Vector2.new(v.X, v.Y)).Magnitude
        if d < bd then bd = d; best = p end
    end
    return best
end

local function startAimbot()
    local ab      = ST.AB
    local running = false
    local locked  = nil

    ST.AimbotConns.t1 = UIS.TextBoxFocused:Connect(function() ST.AimbotTyping=true end)
    ST.AimbotConns.t2 = UIS.TextBoxFocusReleased:Connect(function() ST.AimbotTyping=false end)

    ST.AimbotConns.render = RunService.RenderStepped:Connect(function()
        local cam = workspace.CurrentCamera
        pcall(function()
            local fov = ST.AimbotFOV
            if fov then
                if ab.FOVShow and ST.AimbotOn then
                    fov.Radius=ab.FOVAmt; fov.Thickness=1; fov.NumSides=60; fov.Filled=false
                    fov.Transparency=0.5; fov.Visible=true
                    fov.Color = locked and Color3.fromRGB(255,70,70) or C.Yellow
                    local mp = UIS:GetMouseLocation()
                    fov.Position = Vector2.new(mp.X, mp.Y)
                else
                    fov.Visible = false
                end
            end
        end)

        if not running or not ST.AimbotOn then return end

        if not locked then
            locked = aimbotFind(); ST.AimbotLocked = locked
        else
            local ch = locked.Character
            local pt = ch and (ch:FindFirstChild(ab.Part) or ch:FindFirstChild("HumanoidRootPart"))
            if not ch or not pt then locked=nil; ST.AimbotLocked=nil; return end
            local hm = ch:FindFirstChildOfClass("Humanoid")
            if ab.AliveChk and hm and hm.Health<=0 then locked=nil; ST.AimbotLocked=nil; return end
            pcall(function()
                if ab.Smooth > 0 then
                    TweenService:Create(cam, TweenInfo.new(ab.Smooth, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                        {CFrame=CFrame.new(cam.CFrame.Position, pt.Position)}):Play()
                else
                    cam.CFrame = CFrame.new(cam.CFrame.Position, pt.Position)
                end
            end)
        end
    end)

    ST.AimbotConns.began = UIS.InputBegan:Connect(function(inp)
        if ST.AimbotTyping or not ST.AimbotOn then return end
        if inp.UserInputType == Enum.UserInputType.MouseButton2 then
            if ab.Toggle then
                running = not running
                if not running then locked=nil; ST.AimbotLocked=nil end
            else
                running = true
            end
        end
    end)

    ST.AimbotConns.ended = UIS.InputEnded:Connect(function(inp)
        if ST.AimbotTyping or ab.Toggle then return end
        if inp.UserInputType == Enum.UserInputType.MouseButton2 then
            running=false; locked=nil; ST.AimbotLocked=nil
        end
    end)
end

local function stopAimbot()
    for _, c in pairs(ST.AimbotConns) do pcall(function() c:Disconnect() end) end
    ST.AimbotConns = {}
    pcall(function() if ST.AimbotFOV then ST.AimbotFOV.Visible=false end end)
    ST.AimbotLocked = nil
end

