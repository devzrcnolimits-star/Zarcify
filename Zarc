-- ============================================================
-- UTILITIES
-- ============================================================
local function Log(msg)
    local t = os.clock()
    local entry = string.format("[%.1fs] %s", t, msg)
    table.insert(State.Logs, 1, entry)
    if #State.Logs > 50 then table.remove(State.Logs) end
end

local function Tween(obj, info, props)
    TweenService:Create(obj, info, props):Play()
end

local function MakePadding(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 0)
    p.PaddingRight  = UDim.new(0, right  or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft   = UDim.new(0, left   or 0)
    p.Parent = parent
    return p
end

local function MakeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function MakeStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color     = color or CONFIG.Border
    s.Thickness = thickness or 1
    s.Parent    = parent
    return s
end

-- ============================================================
-- HIGHLIGHT ENGINE
-- ============================================================
local function GetHighlight(player)
    return State.PlayerHighlights[player]
end

local function ApplyHighlight(player, color, transparency, fillEnabled, outlineOnly)
    if not player or not player.Character then
        Log("No character for " .. (player and player.Name or "?"))
        return
    end

    local existing = GetHighlight(player)
    if existing then existing:Destroy() end

    local hl = Instance.new("Highlight")
    hl.FillColor           = color        or State.HighlightColor
    hl.OutlineColor        = color        or State.HighlightColor
    hl.FillTransparency    = (not fillEnabled or outlineOnly) and 1 or (transparency or State.Transparency)
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee             = player.Character
    hl.Parent              = player.Character

    State.PlayerHighlights[player] = hl
    Log("Highlighted: " .. player.Name)

    -- re-apply on respawn
    player.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        if GetHighlight(player) then
            local h2 = Instance.new("Highlight")
            h2.FillColor           = hl.FillColor
            h2.OutlineColor        = hl.OutlineColor
            h2.FillTransparency    = hl.FillTransparency
            h2.OutlineTransparency = 0
            h2.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
            h2.Adornee             = char
            h2.Parent              = char
            State.PlayerHighlights[player] = h2
        end
    end)
end

local function RemoveHighlight(player)
    local hl = GetHighlight(player)
    if hl then
        hl:Destroy()
        State.PlayerHighlights[player] = nil
        Log("Removed highlight: " .. player.Name)
    end
end

local function HighlightAll()
    for _, p in ipairs(Players:GetPlayers()) do
        ApplyHighlight(p, State.HighlightColor, State.Transparency, State.FillEnabled, State.OutlineOnly)
    end
    Log("Highlighted all players")
end

local function ClearAll()
    for p, _ in pairs(State.PlayerHighlights) do
        RemoveHighlight(p)
    end
    Log("Cleared all highlights")
end

