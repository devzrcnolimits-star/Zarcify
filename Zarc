        on = not on
        Tween(track, TweenInfo.new(0.15), {BackgroundColor3 = on and Color3.fromRGB(35,134,54) or CONFIG.Border})
        Tween(thumb, TweenInfo.new(0.15), {Position = on and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)})
        callback(on)
    end)
end

