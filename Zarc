local function SetTab(name)
    ActiveTab = name
    for _, t in pairs(TabStates) do
        local isActive = t.Name == name
        t.Label.TextColor3 = isActive and CONFIG.Accent or CONFIG.TextMuted
        t.Underline.Visible = isActive
    end
    -- show/hide content frames (created below)
    for _, f in ipairs(Window:GetChildren()) do
        if f:IsA("Frame") and f.Name:match("^Tab_") then
            f.Visible = (f.Name == "Tab_" .. name)
        end
    end
end

