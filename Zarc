local function MakePlayerRow(player)
    local row = Instance.new("TextButton")
    row.Name              = player.Name
    row.Size              = UDim2.new(1, 0, 0, 42)
    row.BackgroundColor3  = CONFIG.Surface
    row.Text              = ""
    row.AutoButtonColor   = false
    row.BorderSizePixel   = 0
    row.Parent            = PlayerListFrame
    MakeCorner(row, 5)
    local stroke = MakeStroke(row, CONFIG.Border, 1)

    -- Avatar circle
    local initials = player.Name:sub(1,2):upper()
    local avatarColors = {
        Color3.fromRGB(31,111,235), Color3.fromRGB(137,87,229),
        Color3.fromRGB(35,134,54),  Color3.fromRGB(218,54,51),
        Color3.fromRGB(163,113,31),
    }
    local avatarColor = avatarColors[(#player.Name % #avatarColors) + 1]

    local avatar = Instance.new("Frame")
    avatar.Size             = UDim2.new(0, 30, 0, 30)
    avatar.Position         = UDim2.new(0, 8, 0.5, -15)
    avatar.BackgroundColor3 = avatarColor
    avatar.BorderSizePixel  = 0
    avatar.Parent           = row
    MakeCorner(avatar, 5)

    local initLabel = Instance.new("TextLabel")
    initLabel.Size              = UDim2.new(1,0,1,0)
    initLabel.BackgroundTransparency = 1
    initLabel.Text              = initials
    initLabel.TextColor3        = Color3.new(1,1,1)
    initLabel.TextSize          = 13
    initLabel.Font              = Enum.Font.GothamBold
    initLabel.Parent            = avatar

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size              = UDim2.new(1, -80, 0, 20)
    nameLabel.Position          = UDim2.new(0, 48, 0, 6)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text              = player.Name
    nameLabel.TextColor3        = CONFIG.TextPrimary
    nameLabel.TextSize          = 14
    nameLabel.Font              = Enum.Font.GothamBold
    nameLabel.TextXAlignment    = Enum.TextXAlignment.Left
    nameLabel.Parent            = row

    local hlDot = Instance.new("Frame")
    hlDot.Size              = UDim2.new(0, 10, 0, 10)
    hlDot.Position          = UDim2.new(1, -18, 0.5, -5)
    hlDot.BackgroundColor3  = Color3.fromRGB(48,54,61)
    hlDot.BorderSizePixel   = 0
    hlDot.Parent            = row
    MakeCorner(hlDot, 10)

    local function UpdateDot()
        local hl = GetHighlight(player)
        if hl then
            hlDot.BackgroundColor3 = hl.FillColor
        else
            hlDot.BackgroundColor3 = Color3.fromRGB(48,54,61)
        end
    end
    UpdateDot()

    row.MouseButton1Click:Connect(function()
        State.SelectedPlayer = player
        for _, r in pairs(PlayerRows) do
            r.Stroke.Color = CONFIG.Border
            r.Frame.BackgroundColor3 = CONFIG.Surface
        end
        stroke.Color = CONFIG.Accent
        row.BackgroundColor3 = Color3.fromRGB(13, 33, 55)
        Log("Selected: " .. player.Name)
    end)

    PlayerRows[player] = { Frame = row, Dot = hlDot, Stroke = stroke, Update = UpdateDot }
    return row
end

local function RefreshPlayers()
    for _, child in ipairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    PlayerRows = {}
    for _, p in ipairs(Players:GetPlayers()) do
        MakePlayerRow(p)
    end
end

Players.PlayerAdded:Connect(function(p)
    MakePlayerRow(p)
    Log("Joined: " .. p.Name)
end)
Players.PlayerRemoving:Connect(function(p)
    if PlayerRows[p] then
        PlayerRows[p].Frame:Destroy()
        PlayerRows[p] = nil
    end
    if State.SelectedPlayer == p then State.SelectedPlayer = nil end
    RemoveHighlight(p)
    Log("Left: " .. p.Name)
end)

