-- Chat command handler
local function HandleChat(msg)
    msg = msg:lower():gsub("^%s+","")
    if msg:sub(1,3) == ":hl" then
        local name = msg:sub(5):match("^%s*(.-)%s*$")
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(name) then
                ApplyHighlight(p, State.HighlightColor, State.Transparency, State.FillEnabled, State.OutlineOnly)
                return
            end
        end
        Log("Player not found: " .. name)
    elseif msg == ":hlall" or msg == ":esp" then
        HighlightAll()
    elseif msg:sub(1,5) == ":unhl" then
        local name = msg:sub(7):match("^%s*(.-)%s*$")
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(name) then RemoveHighlight(p); return end
        end
    elseif msg == ":clearhl" then
        ClearAll()
    elseif msg:sub(1,6) == ":color" then
        local name = msg:sub(8):match("^%s*(.-)%s*$")
        for _, c in ipairs(CONFIG.HighlightColors) do
            if c.Name:lower() == name then
                State.HighlightColor = c.Color
                Log("Color: " .. c.Name)
                return
            end
        end
        Log("Unknown color: " .. name)
    elseif msg:sub(1,3) == ":tp" then
        local name = msg:sub(5):match("^%s*(.-)%s*$")
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(name) and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                local lhrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp and lhrp then lhrp.CFrame = hrp.CFrame + Vector3.new(0,3,0) end
                return
            end
        end
    end
end

LocalPlayer.Chatted:Connect(HandleChat)

