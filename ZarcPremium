--// ============================================================
--// MISC ENGINE (No Spread, No Recoil, Rapid Fire, Wallbang)
--// ============================================================
local function StartMiscHook()
    if State.MiscHooked then return end
    local ok,mt=pcall(getrawmetatable,game)
    if not ok then Log("MISC HOOK: NO GETRAWMETATABLE"); return end
    local oldNC=mt.__namecall
    State.MiscOriginal=oldNC
    local ok2=pcall(setreadonly,mt,false)
    if not ok2 then Log("MISC HOOK: NO SETREADONLY"); return end

    mt.__namecall=newcclosure(function(self,...)
        local method=getnamecallmethod()

        if method=="Raycast" and self==workspace then
            local args={...}
            -- No Spread: zero out any random offset in direction
            if State.NoSpread and typeof(args[2])=="Vector3" then
                args[2]=args[2].Unit*(args[2].Magnitude)
            end
            -- No Recoil: keep direction perfectly level (zero Y deviation)
            if State.NoRecoil and typeof(args[2])=="Vector3" then
                local d=args[2]
                args[2]=Vector3.new(d.X,math.clamp(d.Y,-0.01,0.01),d.Z)
            end
            -- Wallbang: ignore all parts by using a params that hits through everything
            if State.Wallbang and typeof(args[3])=="RaycastParams" then
                local rp=RaycastParams.new()
                rp.FilterType=Enum.RaycastFilterType.Exclude
                rp.FilterDescendantsInstances={}
                args[3]=rp
            end
            return oldNC(self,table.unpack(args))
        end

        -- Rapid Fire: intercept FireServer on tool remotes to fire faster
        if State.RapidFire and (method=="FireServer" or method=="InvokeServer") then
            oldNC(self,...) -- fire once normally
            task.delay(0.01,function() pcall(oldNC,self,...) end) -- fire again quickly
        end

        return oldNC(self,...)
    end)

    setreadonly(mt,true)
    State.MiscHooked=true; Log("MISC HOOK ACTIVE")
end

local function StopMiscHook()
    if not State.MiscHooked then return end
    local ok,mt=pcall(getrawmetatable,game)
    if ok then
        pcall(setreadonly,mt,false)
        mt.__namecall=State.MiscOriginal
        pcall(setreadonly,mt,true)
    end
    State.MiscHooked=false; State.MiscOriginal=nil; Log("MISC HOOK OFF")
end

local function RefreshMiscHook()
    local needHook = State.NoSpread or State.NoRecoil or State.RapidFire or State.Wallbang
    if needHook and not State.MiscHooked then StartMiscHook()
    elseif not needHook and State.MiscHooked then StopMiscHook() end
end

