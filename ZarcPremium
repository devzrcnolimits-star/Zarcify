-- ============================================================
-- FLY SYSTEM (stealthy: CFrame-based, no BodyMover instances)
-- ============================================================
local function StartFly()
    local char = LocalPlayer.Character
    if not char then Log("NO CHARACTER"); return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    hum.PlatformStand = false
    local stateConn = hum.StateChanged:Connect(function(_, new)
        if State.Flying and new ~= Enum.HumanoidStateType.Running then
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
        end
    end)
    State.FlyStateConn = stateConn

    local lastCF = hrp.CFrame

    State.FlyConnection = RunService.Heartbeat:Connect(function(dt)
        local cam = workspace.CurrentCamera
        if not cam or not hrp or not hrp.Parent then return end

        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then dir = dir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0,1,0) end

        local targetPos = lastCF.Position + (dir.Magnitude > 0 and dir.Unit * State.FlySpeed * dt or Vector3.zero)
        local lookDir   = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
        local newCF
        if lookDir.Magnitude > 0.01 then
            newCF = CFrame.new(targetPos, targetPos + lookDir)
        else
            newCF = CFrame.new(targetPos) * (lastCF - lastCF.Position)
        end

        hrp.CFrame = newCF
        lastCF     = newCF
        hrp.AssemblyLinearVelocity  = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end)

    State.Flying = true
    Log("FLY ON | WASD + SPACE + CTRL")
end

local function StopFly()
    if State.FlyConnection then State.FlyConnection:Disconnect(); State.FlyConnection = nil end
    if State.FlyStateConn  then State.FlyStateConn:Disconnect();  State.FlyStateConn  = nil end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hum then
            hum.PlatformStand = false
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
        end
        if hrp then
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end
    State.Flying = false
    Log("FLY OFF")
end

local function ToggleFly()
    if State.Flying then StopFly() else StartFly() end
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if State.Flying then StopFly(); StartFly() end
end)

-- ============================================================
-- HIGHLIGHT ENGINE
-- ============================================================
local function GetHighlight(player)
    return State.PlayerHighlights[player]
end

local function ApplyHighlight(player, color, transparency, fillEnabled, outlineOnly)
    if not player or not player.Character then
        Log("NO CHAR: " .. (player and player.Name or "?")); return
    end
    local ex = GetHighlight(player)
    if ex then ex:Destroy() end
    local hl = Instance.new("Highlight")
    hl.FillColor           = color or State.HighlightColor
    hl.OutlineColor        = color or State.HighlightColor
    hl.FillTransparency    = (not fillEnabled or outlineOnly) and 1 or (transparency or State.Transparency)
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee             = player.Character
    hl.Parent              = player.Character
    State.PlayerHighlights[player] = hl
    Log("HL ON: " .. player.Name)
    player.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        if GetHighlight(player) then
            local h2 = Instance.new("Highlight")
            h2.FillColor           = hl.FillColor
            h2.OutlineColor        = hl.OutlineColor
            h2.FillTransparency    = hl.FillTransparency
            h2.OutlineTransparency = 0
            h2.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
            h2.Adornee             = char
            h2.Parent              = char
            State.PlayerHighlights[player] = h2
        end
    end)
end

local function RemoveHighlight(player)
    local hl = GetHighlight(player)
    if hl then
        hl:Destroy()
        State.PlayerHighlights[player] = nil
        Log("HL OFF: " .. player.Name)
    end
end

local function HighlightAll()
    for _, p in ipairs(Players:GetPlayers()) do
        ApplyHighlight(p, State.HighlightColor, State.Transparency, State.FillEnabled, State.OutlineOnly)
    end
    Log("ALL HIGHLIGHTED")
end

local function ClearAll()
    for p in pairs(State.PlayerHighlights) do RemoveHighlight(p) end
    Log("ALL CLEARED")
end

