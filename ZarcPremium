-- ---- Box ESP ----
local State_BoxESP     = false
local State_BoxLines   = {}

local function ClearBoxes()
    for _, lines in pairs(State_BoxLines) do
        for _, l in ipairs(lines) do
            pcall(function() l.Visible = false; l:Remove() end)
        end
    end
    State_BoxLines = {}
end

local function DrawBox(player)
    if not player.Character then return end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    local hum  = player.Character:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    -- 4 corner lines of a 2D box
    local lines = {}
    for i = 1, 4 do
        local l = Drawing.new("Line")
        l.Thickness = 1.5
        l.Color     = State.HighlightColor
        l.Visible   = false
        l.ZIndex    = 5
        table.insert(lines, l)
    end
    State_BoxLines[player] = lines
end

local function UpdateBoxes()
    for player, lines in pairs(State_BoxLines) do
        local char = player.Character
        if not char then
            for _, l in ipairs(lines) do l.Visible = false end
            continue
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then
            for _, l in ipairs(lines) do l.Visible = false end
            continue
        end

        local cam    = workspace.CurrentCamera
        local height = 5.5
        local width  = 2.2
        local cf     = root.CFrame

        local corners3D = {
            cf * Vector3.new(-width, -height/2, 0),
            cf * Vector3.new( width, -height/2, 0),
            cf * Vector3.new( width,  height,   0),
            cf * Vector3.new(-width,  height,   0),
        }

        local pts2D = {}
        local allOnScreen = true
        for _, c3 in ipairs(corners3D) do
            local v, onScreen = cam:WorldToViewportPoint(c3)
            if not onScreen then allOnScreen = false end
            table.insert(pts2D, Vector2.new(v.X, v.Y))
        end

        if allOnScreen then
            lines[1].From = pts2D[1]; lines[1].To = pts2D[2]; lines[1].Visible = true
            lines[2].From = pts2D[2]; lines[2].To = pts2D[3]; lines[2].Visible = true
            lines[3].From = pts2D[3]; lines[3].To = pts2D[4]; lines[3].Visible = true
            lines[4].From = pts2D[4]; lines[4].To = pts2D[1]; lines[4].Visible = true
            for _, l in ipairs(lines) do l.Color = State.HighlightColor end
        else
            for _, l in ipairs(lines) do l.Visible = false end
        end
    end
end

local State_BoxConn = nil

local function EnableBoxESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then DrawBox(p) end
    end
    State_BoxConn = RunService.RenderStepped:Connect(UpdateBoxes)
    Log("BOX ESP ON")
end

local function DisableBoxESP()
    if State_BoxConn then State_BoxConn:Disconnect(); State_BoxConn = nil end
    ClearBoxes()
    Log("BOX ESP OFF")
end

Players.PlayerAdded:Connect(function(p)
    if State_BoxESP then
        p.CharacterAdded:Connect(function()
            task.wait(0.5)
            if State_BoxESP then DrawBox(p) end
        end)
    end
end)
Players.PlayerRemoving:Connect(function(p)
    if State_BoxLines[p] then
        for _, l in ipairs(State_BoxLines[p]) do
            pcall(function() l.Visible=false; l:Remove() end)
        end
        State_BoxLines[p] = nil
    end
end)

