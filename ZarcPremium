local function ApplySpeed()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    if State_SpeedActive then
        -- Keep WalkSpeed at 16 so server-side property checks pass
        -- Use a BodyVelocity to actually move faster, hidden in HRP
        hum.WalkSpeed = 16
        hum.JumpPower = State_JumpPower

        -- Remove existing speed BV if any
        local existing = hrp:FindFirstChild("_ZarcSpeed")
        if existing then existing:Destroy() end

        local bv = Instance.new("BodyVelocity")
        bv.Name     = "_ZarcSpeed"
        bv.MaxForce = Vector3.new(1e4, 0, 1e4)  -- no Y force so gravity still applies
        bv.Velocity = Vector3.zero
        bv.Parent   = hrp

        -- Drive the BodyVelocity using the humanoid move direction
        if State.SpeedConn then State.SpeedConn:Disconnect() end
        State.SpeedConn = RunService.Heartbeat:Connect(function()
            if not State_SpeedActive then return end
            local c2 = LocalPlayer.Character
            if not c2 then return end
            local h2   = c2:FindFirstChildOfClass("Humanoid")
            local r2   = c2:FindFirstChild("HumanoidRootPart")
            local bv2  = r2 and r2:FindFirstChild("_ZarcSpeed")
            if not h2 or not r2 or not bv2 then return end

            local md = h2.MoveDirection
            if md.Magnitude > 0 then
                -- Scale up the natural move direction by desired speed
                bv2.Velocity = md * (State_WalkSpeed - 16)
            else
                bv2.Velocity = Vector3.zero
            end
            -- Continuously reset WalkSpeed in case server resets it
            h2.WalkSpeed = 16
        end)
    else
        -- Clean up
        if State.SpeedConn then State.SpeedConn:Disconnect(); State.SpeedConn = nil end
        if hrp then
            local existing = hrp:FindFirstChild("_ZarcSpeed")
            if existing then existing:Destroy() end
        end
        if hum then
            hum.WalkSpeed = 16
            hum.JumpPower = 50
        end
    end
end

