--// SILENT AIM ENGINE
--// ============================================================
local function SilentGetTarget()
    local cam=workspace.CurrentCamera
    local mp=UserInputService:GetMouseLocation()
    local ss=State.SilentSettings
    local best,bestDist=nil,ss.FOVRadius
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer then continue end
        local char=p.Character; if not char then continue end
        local part=char:FindFirstChild(ss.LockPart) or char:FindFirstChild("HumanoidRootPart")
        local hum=char:FindFirstChildOfClass("Humanoid")
        if not part or not hum then continue end
        if ss.AliveCheck and hum.Health<=0 then continue end
        if ss.TeamCheck  and p.Team==LocalPlayer.Team then continue end
        local v,on=cam:WorldToViewportPoint(part.Position)
        if not on then continue end
        local d=(Vector2.new(mp.X,mp.Y)-Vector2.new(v.X,v.Y)).Magnitude
        if (not ss.CheckFOV or d<bestDist) then bestDist=d; best=part end
    end
    return best
end

local function StartSilentAim()
    if State.SilentHooked then return end
    local ok,mt=pcall(getrawmetatable,game)
    if not ok then Log("SA: NO GETRAWMETATABLE"); return end
    local oldNC=mt.__namecall
    State.SilentOriginal=oldNC
    local ok2=pcall(setreadonly,mt,false)
    if not ok2 then Log("SA: NO SETREADONLY"); return end
    mt.__namecall=newcclosure(function(self,...)
        local method=getnamecallmethod()
        if State.SilentOn then
            if method=="Raycast" and self==workspace then
                local target=SilentGetTarget()
                if target then
                    local args={...}
                    if typeof(args[1])=="Vector3" then
                        args[2]=target.Position-args[1]
                        return oldNC(self,table.unpack(args))
                    end
                end
            elseif (method=="FindPartOnRayWithWhitelist" or method=="FindPartOnRay") and self==workspace then
                local target=SilentGetTarget()
                if target then
                    local args={...}
                    if typeof(args[1])=="Ray" then
                        args[1]=Ray.new(args[1].Origin,target.Position-args[1].Origin)
                        return oldNC(self,table.unpack(args))
                    end
                end
            end
        end
        return oldNC(self,...)
    end)
    setreadonly(mt,true)
    State.SilentHooked=true; Log("SILENT AIM ON")
end

local function StopSilentAim()
    if not State.SilentHooked then return end
    local ok,mt=pcall(getrawmetatable,game)
    if ok then
        pcall(setreadonly,mt,false)
        mt.__namecall=State.SilentOriginal
        pcall(setreadonly,mt,true)
    end
    State.SilentHooked=false; State.SilentOriginal=nil; Log("SILENT AIM OFF")
end

--// ============================================================
--// TRIGGERBOT ENGINE
--// ============================================================
local function StartTriggerbot()
    State.TriggerConn=RunService.Heartbeat:Connect(function()
        if not State.TriggerOn then return end
        local cam=workspace.CurrentCamera
        local mp=UserInputService:GetMouseLocation()
        local unitRay=cam:ScreenPointToRay(mp.X,mp.Y)
        local rp=RaycastParams.new()
        rp.FilterType=Enum.RaycastFilterType.Exclude
        rp.FilterDescendantsInstances={LocalPlayer.Character or game}
        local result=workspace:Raycast(unitRay.Origin,unitRay.Direction*1000,rp)
        if result and result.Instance then
            local hit=result.Instance
            -- check if part belongs to an enemy player
            for _,p in ipairs(Players:GetPlayers()) do
                if p==LocalPlayer then continue end
                if p.Character and hit:IsDescendantOf(p.Character) then
                    local hum=p.Character:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health>0 then
                        task.wait(State.TriggerDelay)
                        -- simulate mouse click
                        if mouse1press then
                            pcall(mouse1press)
                            task.wait(0.05)
                            pcall(mouse1release)
                        else
                            -- fallback: use InputService simulation
                            local vInputService = game:GetService("VirtualInputManager")
                            pcall(function()
                                vInputService:SendMouseButtonEvent(0,0,0,true,game,0)
                                task.wait(0.05)
                                vInputService:SendMouseButtonEvent(0,0,0,false,game,0)
                            end)
                        end
                    end
                end
            end
        end
    end)
    Log("TRIGGERBOT ON")
end

local function StopTriggerbot()
    if State.TriggerConn then State.TriggerConn:Disconnect(); State.TriggerConn=nil end
    Log("TRIGGERBOT OFF")
