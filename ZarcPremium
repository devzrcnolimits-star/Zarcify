-- Reusable slider row for list-based tabs
local function MakeSliderRow(parent, labelText, minVal, maxVal, defaultVal, decimals, order, onChanged)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1,0,0,40)
    row.BackgroundColor3 = CFG.Surface
    row.BorderSizePixel  = 0
    row.LayoutOrder      = order
    row.Parent           = parent
    Corner(row,2); Stroke(row,CFG.Border,1); Pad(row,5,10,5,10)

    local fmt = decimals>0 and ("%."..decimals.."f") or "%d"
    local lbl = Lbl(row,labelText,11,CFG.TextMuted); lbl.Size=UDim2.new(0.6,0,0,14)
    local valLbl = Lbl(row,string.format(fmt,defaultVal),11,CFG.TextPrimary,Enum.TextXAlignment.Right)
    valLbl.Size=UDim2.new(0.4,0,0,14)

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,0,0,4); track.Position = UDim2.new(0,0,1,-10)
    track.BackgroundColor3 = CFG.Border; track.BorderSizePixel = 0; track.Parent = row
    Corner(track,2)

    local rel0 = (defaultVal-minVal)/(maxVal-minVal)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(rel0,0,1,0); fill.BackgroundColor3 = CFG.Accent
    fill.BorderSizePixel = 0; fill.Parent = track; Corner(fill,2)

    local handle = Btn(track,"",Color3.new(1,1,1),UDim2.new(0,12,0,12),UDim2.new(rel0,-6,0.5,-6))
    Stroke(handle,CFG.Border,0)

    local drag=false
    handle.MouseButton1Down:Connect(function() drag=true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local rel=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            local val=decimals>0 and math.floor((minVal+rel*(maxVal-minVal))*(10^decimals))/(10^decimals) or math.floor(minVal+rel*(maxVal-minVal))
            fill.Size=UDim2.new(rel,0,1,0); handle.Position=UDim2.new(rel,-6,0.5,-6)
            valLbl.Text=string.format(fmt,val); onChanged(val)
        end
    end)
end

