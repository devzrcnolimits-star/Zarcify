-- AIMBOT ENGINE
-- ================================================================
local function AimbotFind()
    local cam = workspace.CurrentCamera
    local mp = UserInputService:GetMouseLocation()
    local cfg = S.AimbotCfg
    local best, bd = nil, cfg.FOVAmount
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local ch = p.Character
        if not ch then continue end
        local pt = ch:FindFirstChild(cfg.LockPart) or ch:FindFirstChild("HumanoidRootPart")
        local hm = ch:FindFirstChildOfClass("Humanoid")
        if not pt or not hm then continue end
        if cfg.AliveCheck and hm.Health <= 0 then continue end
        if cfg.TeamCheck and p.Team == LocalPlayer.Team then continue end
        local v, on = cam:WorldToViewportPoint(pt.Position)
        if not on then continue end
        local d = (Vector2.new(mp.X, mp.Y) - Vector2.new(v.X, v.Y)).Magnitude
        if d < bd then bd = d; best = p end
    end
    return best
end

local function StartAimbot()
    local cfg=S.AimbotCfg
    local running=false
    local locked=nil

    S.AimbotConns.t1=UserInputService.TextBoxFocused:Connect(function() S.AimbotTyping=true end)
    S.AimbotConns.t2=UserInputService.TextBoxFocusReleased:Connect(function() S.AimbotTyping=false end)

    S.AimbotConns.render=RunService.RenderStepped:Connect(function()
        local cam=workspace.CurrentCamera
        pcall(function()
            local fov=S.AimbotFOV
            if fov then
                if cfg.FOVVisible and S.AimbotOn then
                    fov.Radius=cfg.FOVAmount; fov.Thickness=1; fov.NumSides=60; fov.Filled=false
                    fov.Transparency=0.5; fov.Visible=true
                    fov.Color=locked and Color3.fromRGB(255,70,70) or CFG.Accent
                    local mp=UserInputService:GetMouseLocation()
                    fov.Position=Vector2.new(mp.X,mp.Y)
                else fov.Visible=false end
            end
        end)
        if not running or not S.AimbotOn then return end
        if not locked then
            locked=AimbotFind(); S.AimbotLocked=locked
        else
            local ch=locked.Character
            local pt=ch and (ch:FindFirstChild(cfg.LockPart) or ch:FindFirstChild("HumanoidRootPart"))
            if not ch or not pt then locked=nil; S.AimbotLocked=nil; return end
            local hm=ch:FindFirstChildOfClass("Humanoid")
            if cfg.AliveCheck and hm and hm.Health<=0 then locked=nil; S.AimbotLocked=nil; return end
            pcall(function()
                if cfg.Sensitivity>0 then
                    TweenService:Create(cam,TweenInfo.new(cfg.Sensitivity,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),
                        {CFrame=CFrame.new(cam.CFrame.Position,pt.Position)}):Play()
                else
                    cam.CFrame=CFrame.new(cam.CFrame.Position,pt.Position)
                end
            end)
        end
    end)

    S.AimbotConns.began=UserInputService.InputBegan:Connect(function(inp)
        if S.AimbotTyping or not S.AimbotOn then return end
        if inp.UserInputType==Enum.UserInputType.MouseButton2 then
            if cfg.Toggle then running=not running; if not running then locked=nil; S.AimbotLocked=nil end
            else running=true end
        end
    end)

    S.AimbotConns.ended=UserInputService.InputEnded:Connect(function(inp)
        if S.AimbotTyping or cfg.Toggle then return end
        if inp.UserInputType==Enum.UserInputType.MouseButton2 then
            running=false; locked=nil; S.AimbotLocked=nil
        end
    end)
    Log("AIMBOT ON")
end

local function StopAimbot()
    for _,c in pairs(S.AimbotConns) do pcall(function() c:Disconnect() end) end
    S.AimbotConns={}
    pcall(function() if S.AimbotFOV then S.AimbotFOV.Visible=false end end)
    S.AimbotLocked=nil; Log("AIMBOT OFF")
end

-- ================================================================
-- SILENT AIM ENGINE
-- ================================================================
local function SilentFind()
    local cam = workspace.CurrentCamera
    local mp = UserInputService:GetMouseLocation()
    local cfg = S.SilentCfg
    local best, bd = nil, cfg.FOVRadius
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local ch = p.Character
        if not ch then continue end
        local pt = ch:FindFirstChild(cfg.LockPart) or ch:FindFirstChild("HumanoidRootPart")
        local hm = ch:FindFirstChildOfClass("Humanoid")
        if not pt or not hm then continue end
        if cfg.AliveCheck and hm.Health <= 0 then continue end
        if cfg.TeamCheck and p.Team == LocalPlayer.Team then continue end
        local v, on = cam:WorldToViewportPoint(pt.Position)
        if not on then continue end
        local d = (Vector2.new(mp.X, mp.Y) - Vector2.new(v.X, v.Y)).Magnitude
        if not cfg.CheckFOV or d < bd then bd = d; best = pt end
    end
    return best
end

local function StartSilentAim()
    if S.SilentHooked then return end
    local ok,mt=pcall(getrawmetatable,game)
    if not ok then Log("SA: NO GETRAWMETATABLE"); return end
    local oldNC=mt.__namecall; S.SilentOrig=oldNC
    if not pcall(setreadonly,mt,false) then Log("SA: NO SETREADONLY"); return end
    mt.__namecall=newcclosure(function(self,...)
        local method=getnamecallmethod()
        if S.SilentOn then
            if method=="Raycast" and self==workspace then
                local target=SilentFind()
                if target then
                    local args={...}
                    if typeof(args[1])=="Vector3" then
                        args[2]=target.Position-args[1]
                        return oldNC(self,table.unpack(args))
                    end
                end
            elseif (method=="FindPartOnRayWithWhitelist" or method=="FindPartOnRay") and self==workspace then
                local target=SilentFind()
                if target then
                    local args={...}
                    if typeof(args[1])=="Ray" then
                        args[1]=Ray.new(args[1].Origin,target.Position-args[1].Origin)
                        return oldNC(self,table.unpack(args))
                    end
                end
            end
        end
        return oldNC(self,...)
    end)
    pcall(setreadonly,mt,true)
    S.SilentHooked=true; Log("SILENT AIM ON")
end

local function StopSilentAim()
    if not S.SilentHooked then return end
    local ok,mt=pcall(getrawmetatable,game)
    if ok then
        pcall(setreadonly,mt,false); mt.__namecall=S.SilentOrig; pcall(setreadonly,mt,true)
    end
    S.SilentHooked=false; S.SilentOrig=nil; Log("SILENT AIM OFF")
end

-- ================================================================
-- TRIGGERBOT ENGINE
-- ================================================================
local function StartTriggerbot()
    S.TriggerConn=RunService.Heartbeat:Connect(function()
        if not S.TriggerOn then return end
        pcall(function()
            local cam=workspace.CurrentCamera
            local mp=UserInputService:GetMouseLocation()
            local ray=cam:ScreenPointToRay(mp.X,mp.Y)
            local rp=RaycastParams.new()
            rp.FilterType=Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances={LocalPlayer.Character or workspace}
            local res=workspace:Raycast(ray.Origin,ray.Direction*1000,rp)
            if res and res.Instance then
                for _,p in ipairs(Players:GetPlayers()) do
                    if p~=LocalPlayer and p.Character and res.Instance:IsDescendantOf(p.Character) then
                        local hm=p.Character:FindFirstChildOfClass("Humanoid")
                        if hm and hm.Health>0 then
                            task.wait(S.TriggerDelay)
                            if mouse1press  then pcall(mouse1press)  end
                            task.wait(0.05)
                            if mouse1release then pcall(mouse1release) end
                        end
                    end
                end
            end
        end)
    end)
    Log("TRIGGERBOT ON")
end

local function StopTriggerbot()
    if S.TriggerConn then S.TriggerConn:Disconnect(); S.TriggerConn=nil end
    Log("TRIGGERBOT OFF")
end

-- ================================================================
-- MISC HOOK ENGINE
-- ================================================================
local function RefreshMisc()
    local need=S.NoSpread or S.NoRecoil or S.RapidFire or S.Wallbang
    if need and not S.MiscHooked then
        local ok,mt=pcall(getrawmetatable,game)
        if not ok then Log("MISC: NO GETRAWMETATABLE"); return end
        local oldNC=mt.__namecall; S.MiscOrig=oldNC
        if not pcall(setreadonly,mt,false) then Log("MISC: NO SETREADONLY"); return end
        mt.__namecall=newcclosure(function(self,...)
            local method=getnamecallmethod()
            if method=="Raycast" and self==workspace then
                local args={...}
                if S.NoSpread and typeof(args[2])=="Vector3" then
                    local d=args[2]; args[2]=d.Unit*d.Magnitude
                end
                if S.NoRecoil and typeof(args[2])=="Vector3" then
                    local d=args[2]; args[2]=Vector3.new(d.X,math.clamp(d.Y,-0.01,0.01),d.Z)
                end
                if S.Wallbang and typeof(args[3])=="RaycastParams" then
                    local rp=RaycastParams.new()
                    rp.FilterType=Enum.RaycastFilterType.Exclude
                    rp.FilterDescendantsInstances={}
                    args[3]=rp
                end
                return oldNC(self,table.unpack(args))
            end
            if S.RapidFire and (method=="FireServer" or method=="InvokeServer") then
                oldNC(self,...)
                task.delay(0.01,function() pcall(oldNC,self,...) end)
            end
            return oldNC(self,...)
        end)
        pcall(setreadonly,mt,true)
        S.MiscHooked=true; Log("MISC HOOK ON")
