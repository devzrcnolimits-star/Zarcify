local function HandleChat(msg)
    msg = msg:lower():gsub("^%s+","")
    if msg:sub(1,3)==":hl" and msg:sub(1,5)~=":hlal" then
        local name = msg:sub(5):match("^%s*(.-)%s*$")
        for _,p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(name) then
                ApplyHighlight(p,State.HighlightColor,State.Transparency,State.FillEnabled,State.OutlineOnly); return
            end
        end
        Log("NOT FOUND: "..name)
    elseif msg==":hlall" or msg==":esp" then HighlightAll()
    elseif msg:sub(1,5)==":unhl" then
        local name = msg:sub(7):match("^%s*(.-)%s*$")
        for _,p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(name) then RemoveHighlight(p); return end
        end
    elseif msg==":clearhl" then ClearAll()
    elseif msg:sub(1,6)==":color" then
        local name = msg:sub(8):match("^%s*(.-)%s*$")
        for _,c in ipairs(CONFIG.HighlightColors) do
            if c.Name:lower()==name then State.HighlightColor=c.Color; Log("COLOR: "..c.Name); return end
        end
        Log("UNKNOWN: "..name)
    elseif msg:sub(1,3)==":tp" then
        local name = msg:sub(5):match("^%s*(.-)%s*$")
        for _,p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(name) and p.Character then
                local hrp  = p.Character:FindFirstChild("HumanoidRootPart")
                local lhrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp and lhrp then lhrp.CFrame = hrp.CFrame + Vector3.new(0,4,0) end
                return
            end
        end
    elseif msg==":fly" then
        ToggleFly()
        flyStatus.Text       = State.Flying and "STATUS: ON"  or "STATUS: OFF"
        flyStatus.TextColor3 = State.Flying and Color3.fromRGB(88,214,141) or Color3.fromRGB(180,40,40)
        flyToggleBtn.BackgroundColor3 = State.Flying and Color3.fromRGB(35,134,54) or CONFIG.Accent
    elseif msg==":speed" then
        State_SpeedActive = not State_SpeedActive
        ApplySpeed()
        speedStatus.Text       = State_SpeedActive and "STATUS: ON"  or "STATUS: OFF"
        speedStatus.TextColor3 = State_SpeedActive and Color3.fromRGB(88,214,141) or Color3.fromRGB(180,40,40)
        speedToggleBtn.BackgroundColor3 = State_SpeedActive and Color3.fromRGB(35,134,54) or CONFIG.Accent
        Log(State_SpeedActive and "SPEED ON" or "SPEED OFF")
    end
end
