--// ============================================================
--// FLY ENGINE
--// ============================================================
local function StartFly()
    local char=LocalPlayer.Character; if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    hum.PlatformStand=false
    State.FlyStateConn = hum.StateChanged:Connect(function(_,new)
        if State.Flying and new~=Enum.HumanoidStateType.Running then
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
        end
    end)
    local lastCF=hrp.CFrame
    State.FlyConn = RunService.Heartbeat:Connect(function(dt)
        local cam=workspace.CurrentCamera
        if not cam or not hrp or not hrp.Parent then return end
        local dir=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir=dir+cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir=dir-cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir=dir-cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir=dir+cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then dir=dir+Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir=dir-Vector3.new(0,1,0) end
        local tp=lastCF.Position+(dir.Magnitude>0 and dir.Unit*State.FlySpeed*dt or Vector3.zero)
        local ld=Vector3.new(cam.CFrame.LookVector.X,0,cam.CFrame.LookVector.Z)
        local newCF=ld.Magnitude>0.01 and CFrame.new(tp,tp+ld) or CFrame.new(tp)*(lastCF-lastCF.Position)
        hrp.CFrame=newCF; lastCF=newCF
        hrp.AssemblyLinearVelocity=Vector3.zero; hrp.AssemblyAngularVelocity=Vector3.zero
    end)
    State.Flying=true; Log("FLY ON")
end

local function StopFly()
    if State.FlyConn      then State.FlyConn:Disconnect();      State.FlyConn=nil end
    if State.FlyStateConn then State.FlyStateConn:Disconnect(); State.FlyStateConn=nil end
    local char=LocalPlayer.Character
    if char then
        local hum=char:FindFirstChildOfClass("Humanoid")
        local hrp=char:FindFirstChild("HumanoidRootPart")
        if hum then hum.PlatformStand=false; pcall(function()hum:ChangeState(Enum.HumanoidStateType.Running)end) end
        if hrp then hrp.AssemblyLinearVelocity=Vector3.zero; hrp.AssemblyAngularVelocity=Vector3.zero end
    end
    State.Flying=false; Log("FLY OFF")
end

