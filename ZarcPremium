-- ================================================================
local function ApplyHL(player,color,tr,fill,outline)
    if not player or not player.Character then return end
    local ex=S.Highlights[player]; if ex then pcall(function() ex:Destroy() end) end
    pcall(function()
        local h=Instance.new("Highlight")
        h.FillColor=color or S.HLColor; h.OutlineColor=color or S.HLColor
        h.FillTransparency=(not fill or outline) and 1 or (tr or S.HLTrans)
        h.OutlineTransparency=0; h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
        h.Adornee=player.Character; h.Parent=player.Character
        S.Highlights[player]=h
        player.CharacterAdded:Connect(function(char)
            task.wait(0.1)
            if S.Highlights[player] then
                pcall(function()
                    local h2=Instance.new("Highlight")
                    h2.FillColor=h.FillColor; h2.OutlineColor=h.OutlineColor
                    h2.FillTransparency=h.FillTransparency; h2.OutlineTransparency=0
                    h2.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                    h2.Adornee=char; h2.Parent=char; S.Highlights[player]=h2
                end)
            end
        end)
    end)
    Log("HL: "..player.Name)
end

local function RemHL(player)
    local h=S.Highlights[player]
    if h then pcall(function() h:Destroy() end); S.Highlights[player]=nil end
end

local function HLAll()
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then ApplyHL(p,S.HLColor,S.HLTrans,S.HLFill,S.HLOutline) end
    end
end

local function ClearHL()
    for p in pairs(S.Highlights) do RemHL(p) end
end

-- Box ESP -- Drawing only inside this function, never at top level
local function StartBox()
    pcall(function()
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer then
                local ln={}
                for i=1,4 do
                    local l=Drawing.new("Line"); l.Thickness=1.5; l.Color=S.HLColor; l.Visible=false; l.ZIndex=5
                    ln[i]=l
                end
                S.BoxLines[p]=ln
            end
        end
    end)
    S.BoxConn=RunService.RenderStepped:Connect(function()
        local cam=workspace.CurrentCamera
        for pl,ln in pairs(S.BoxLines) do
            pcall(function()
                local ch=pl.Character
                local rt=ch and ch:FindFirstChild("HumanoidRootPart")
                local hm=ch and ch:FindFirstChildOfClass("Humanoid")
                if not rt or not hm or hm.Health<=0 then
                    for i=1,4 do ln[i].Visible=false end; return
                end
                local cf=rt.CFrame; local w,h=2.2,5.5
                local c3={cf*Vector3.new(-w,-h/2,0),cf*Vector3.new(w,-h/2,0),cf*Vector3.new(w,h,0),cf*Vector3.new(-w,h,0)}
                local pts={}; local ok=true
                for _,c in ipairs(c3) do local v,on=cam:WorldToViewportPoint(c); if not on then ok=false end; table.insert(pts,Vector2.new(v.X,v.Y)) end
                if ok then
                    for i=1,4 do ln[i].From=pts[i]; ln[i].To=pts[i%4+1]; ln[i].Color=S.HLColor; ln[i].Visible=true end
                else
                    for i=1,4 do ln[i].Visible=false end
                end
            end)
        end
    end)
end

local function StopBox()
    if S.BoxConn then S.BoxConn:Disconnect(); S.BoxConn=nil end
    for _,ln in pairs(S.BoxLines) do for _,l in ipairs(ln) do pcall(function() l.Visible=false; l:Remove() end) end end
    S.BoxLines={}
end

-- Tracers -- same, Drawing only inside function
local function StartTracers()
