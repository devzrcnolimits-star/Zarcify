local function AimbotGetClosest(fovRadius)
    local cam=workspace.CurrentCamera
    local mp=UserInputService:GetMouseLocation()
    local best,bestDist=nil,fovRadius
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer then continue end
        local char=p.Character; if not char then continue end
        local part=char:FindFirstChild(State.AimbotSettings.LockPart) or char:FindFirstChild("HumanoidRootPart")
        local hum=char:FindFirstChildOfClass("Humanoid")
        if not part or not hum then continue end
        if State.AimbotSettings.AliveCheck and hum.Health<=0 then continue end
        if State.AimbotSettings.TeamCheck  and p.Team==LocalPlayer.Team then continue end
        local v,on=cam:WorldToViewportPoint(part.Position)
        if not on then continue end
        local d=(Vector2.new(mp.X,mp.Y)-Vector2.new(v.X,v.Y)).Magnitude
        if d<bestDist then bestDist=d; best=p end
    end
    return best
end

local function StartAimbot()
    if State.AimbotConns.render then return end
    local ss=State.AimbotSettings
    local fov=State.AimbotFOVCircle
    local running=false
    local locked=nil

    State.AimbotConns.typing1=UserInputService.TextBoxFocused:Connect(function() State.AimbotTyping=true end)
    State.AimbotConns.typing2=UserInputService.TextBoxFocusReleased:Connect(function() State.AimbotTyping=false end)

    State.AimbotConns.render=RunService.RenderStepped:Connect(function()
        local cam=workspace.CurrentCamera
        -- FOV circle
        if fov then
            if ss.FOVVisible and State.AimbotOn then
                fov.Radius=ss.FOVAmount; fov.Thickness=1; fov.NumSides=60; fov.Filled=false
                fov.Color=locked and Color3.fromRGB(255,70,70) or CFG.Accent
                fov.Transparency=0.5; fov.Visible=true
                local mp=UserInputService:GetMouseLocation()
                fov.Position=Vector2.new(mp.X,mp.Y)
            else fov.Visible=false end
        end

        if not running or not State.AimbotOn then return end

        if not locked then
            locked=AimbotGetClosest(ss.FOVAmount)
            State.AimbotLocked=locked
        else
            local char=locked.Character
            local part=char and (char:FindFirstChild(ss.LockPart) or char:FindFirstChild("HumanoidRootPart"))
            if not char or not part then locked=nil; State.AimbotLocked=nil; return end
            local hum=char:FindFirstChildOfClass("Humanoid")
            if ss.AliveCheck and hum and hum.Health<=0 then locked=nil; State.AimbotLocked=nil; return end

            if ss.Sensitivity>0 then
                TweenService:Create(cam,TweenInfo.new(ss.Sensitivity,Enum.EasingStyle.Sine,Enum.EasingDirection.Out),
                    {CFrame=CFrame.new(cam.CFrame.Position,part.Position)}):Play()
            else
                cam.CFrame=CFrame.new(cam.CFrame.Position,part.Position)
            end
        end
    end)

    State.AimbotConns.begun=UserInputService.InputBegan:Connect(function(inp)
        if State.AimbotTyping or not State.AimbotOn then return end
        local rmb=inp.UserInputType==Enum.UserInputType.MouseButton2
        if rmb then
            if ss.Toggle then running=not running; if not running then locked=nil; State.AimbotLocked=nil end
            else running=true end
        end
    end)
    State.AimbotConns.ended=UserInputService.InputEnded:Connect(function(inp)
        if State.AimbotTyping or ss.Toggle then return end
        if inp.UserInputType==Enum.UserInputType.MouseButton2 then
            running=false; locked=nil; State.AimbotLocked=nil
        end
    end)
    Log("AIMBOT ON | HOLD RMB")
end

local function StopAimbot()
    for _,c in pairs(State.AimbotConns) do c:Disconnect() end
    State.AimbotConns={}
    if State.AimbotFOVCircle then State.AimbotFOVCircle.Visible=false end
    State.AimbotLocked=nil; Log("AIMBOT OFF")
end

