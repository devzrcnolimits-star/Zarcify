    track.Position         = UDim2.new(1,-42,0.5,-10)
    track.BackgroundColor3 = default and Color3.fromRGB(35,134,54) or CONFIG.Border
    track.Text             = default and "ON" or "OFF"
    track.TextSize         = 10
    track.Font             = PF
    track.TextColor3       = Color3.new(1,1,1)
    track.BorderSizePixel  = 0
    track.Parent           = container
    MakeCorner(track,2)
