local State_Tracers    = false
local State_TracerLines = {}
local State_TracerConn = nil

local function ClearTracers()
    for _, l in pairs(State_TracerLines) do
        pcall(function() l.Visible=false; l:Remove() end)
    end
    State_TracerLines = {}
end

local function UpdateTracers()
    local cam      = workspace.CurrentCamera
    local viewport = cam.ViewportSize
    local origin   = Vector2.new(viewport.X / 2, viewport.Y) -- bottom center

    for player, line in pairs(State_TracerLines) do
        local char = player.Character
        if not char then line.Visible = false; continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then line.Visible = false; continue end

        local vec, onScreen = cam:WorldToViewportPoint(root.Position)
        if onScreen then
            line.From    = origin
            line.To      = Vector2.new(vec.X, vec.Y)
            line.Color   = State.HighlightColor
            line.Visible = true
        else
            line.Visible = false
        end
    end
end

