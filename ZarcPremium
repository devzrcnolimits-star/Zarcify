local function ApplyHighlight(player, color, tr, fill, outline)
    if not player or not player.Character then return end
    local ex = State.Highlights[player]
    if ex then ex:Destroy() end
    local hl = Instance.new("Highlight")
    hl.FillColor           = color or State.HLColor
    hl.OutlineColor        = color or State.HLColor
    hl.FillTransparency    = (not fill or outline) and 1 or (tr or State.HLTransparency)
    hl.OutlineTransparency = 0
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee             = player.Character
    hl.Parent              = player.Character
    State.Highlights[player] = hl
    player.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        if State.Highlights[player] then
            local h2 = Instance.new("Highlight")
            h2.FillColor=hl.FillColor; h2.OutlineColor=hl.OutlineColor
            h2.FillTransparency=hl.FillTransparency; h2.OutlineTransparency=0
            h2.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
            h2.Adornee=char; h2.Parent=char
            State.Highlights[player] = h2
        end
    end)
    Log("HL ON: "..player.Name)
end

local function RemoveHighlight(player)
    local hl = State.Highlights[player]
    if hl then hl:Destroy(); State.Highlights[player]=nil; Log("HL OFF: "..player.Name) end
end

local function HighlightAll()
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then ApplyHighlight(p,State.HLColor,State.HLTransparency,State.HLFill,State.HLOutline) end
    end; Log("ALL HL")
end

local function ClearAllHL()
    for p in pairs(State.Highlights) do RemoveHighlight(p) end; Log("HL CLEARED")
end

--// Box ESP
local function StartBoxESP()
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local lines={}
            for i=1,4 do
                local l=Drawing.new("Line"); l.Thickness=1.5; l.Color=State.HLColor; l.Visible=false; l.ZIndex=5
                table.insert(lines,l)
            end
            State.BoxLines[p]=lines
        end
    end
    State.BoxConn = RunService.RenderStepped:Connect(function()
        local cam=workspace.CurrentCamera
        for player,lines in pairs(State.BoxLines) do
            local char=player.Character
            local root=char and char:FindFirstChild("HumanoidRootPart")
            local hum=char and char:FindFirstChildOfClass("Humanoid")
            if not root or not hum or hum.Health<=0 then for _,l in ipairs(lines) do l.Visible=false end; continue end
            local cf=root.CFrame; local w=2.2; local h=5.5
            local c3={cf*Vector3.new(-w,-h/2,0),cf*Vector3.new(w,-h/2,0),cf*Vector3.new(w,h,0),cf*Vector3.new(-w,h,0)}
            local pts={}; local ok=true
            for _,c in ipairs(c3) do local v,on=cam:WorldToViewportPoint(c); if not on then ok=false end; table.insert(pts,Vector2.new(v.X,v.Y)) end
            if ok then
                lines[1].From=pts[1];lines[1].To=pts[2];lines[1].Visible=true;lines[1].Color=State.HLColor
                lines[2].From=pts[2];lines[2].To=pts[3];lines[2].Visible=true;lines[2].Color=State.HLColor
                lines[3].From=pts[3];lines[3].To=pts[4];lines[3].Visible=true;lines[3].Color=State.HLColor
                lines[4].From=pts[4];lines[4].To=pts[1];lines[4].Visible=true;lines[4].Color=State.HLColor
            else for _,l in ipairs(lines) do l.Visible=false end end
        end
    end)
    Log("BOX ESP ON")
end

local function StopBoxESP()
    if State.BoxConn then State.BoxConn:Disconnect(); State.BoxConn=nil end
    for _,lines in pairs(State.BoxLines) do for _,l in ipairs(lines) do pcall(function()l.Visible=false;l:Remove()end) end end
    State.BoxLines={}; Log("BOX ESP OFF")
end

