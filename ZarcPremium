local LogFn -- forward declare, replaced after GUI built

local function Log(msg)
    table.insert(S.LogLines, 1, tostring(msg))
    if #S.LogLines > 50 then table.remove(S.LogLines) end
    if LogFn then pcall(LogFn, msg) end
end

local function Tw(obj, ti, props) pcall(function() TweenService:Create(obj,ti,props):Play() end) end

local function Crn(p,r) local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r or 4); c.Parent=p; return c end
local function Str(p,col,th) local s=Instance.new("UIStroke"); s.Color=col or CFG.Border; s.Thickness=th or 1; s.Parent=p; return s end
local function Pad(p,t,r,b,l) local u=Instance.new("UIPadding"); u.PaddingTop=UDim.new(0,t or 0); u.PaddingRight=UDim.new(0,r or 0); u.PaddingBottom=UDim.new(0,b or 0); u.PaddingLeft=UDim.new(0,l or 0); u.Parent=p end

