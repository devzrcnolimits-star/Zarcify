    track.MouseButton1Click:Connect(function()
        on = not on
        Tween(track,TweenInfo.new(0.12),{BackgroundColor3=on and Color3.fromRGB(35,134,54) or CONFIG.Border})
        track.Text = on and "ON" or "OFF"
        callback(on)
    end)
end

