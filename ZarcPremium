local function LoadAimbot()
    if AimbotLoaded then return end
    AimbotLoaded = true

    -- Services already available from outer scope
    local Camera2       = workspace.CurrentCamera
    local ReqDist       = 2000
    local Typing2       = false
    local Running2      = false
    local Animation2    = nil

    AimbotEnv.Settings = {
        Enabled              = true,
        TeamCheck            = false,
        AliveCheck           = true,
        WallCheck            = false,
        Sensitivity          = 0.15,
        ThirdPerson          = false,
        ThirdPersonSensitivity = 3,
        TriggerKey           = "MouseButton2",
        Toggle               = false,
        LockPart             = "Head",
    }
    AimbotEnv.FOVSettings = {
        Enabled      = true,
        Visible      = true,
        Amount       = 90,
        Color        = Color3.fromRGB(255, 210, 50),
        LockedColor  = Color3.fromRGB(255, 70, 70),
        Transparency = 0.5,
        Sides        = 60,
        Thickness    = 1,
        Filled       = false,
    }

    AimbotEnv.FOVCircle          = Drawing.new("Circle")
    AimbotEnv.FOVCircle.Visible  = false
    AimbotEnv.Locked             = nil

    local function CancelLock2()
        AimbotEnv.Locked = nil
        if Animation2 then Animation2:Cancel() end
        AimbotEnv.FOVCircle.Color = AimbotEnv.FOVSettings.Color
    end

    local function GetClosest2()
        local fs = AimbotEnv.FOVSettings
        local ss = AimbotEnv.Settings
        if not AimbotEnv.Locked then
            ReqDist = fs.Enabled and fs.Amount or 2000
            for _, v in next, Players:GetPlayers() do
                if v ~= LocalPlayer then
                    local char = v.Character
                    if char and char:FindFirstChild(ss.LockPart) and char:FindFirstChildOfClass("Humanoid") then
                        if ss.TeamCheck and v.Team == LocalPlayer.Team then continue end
                        if ss.AliveCheck and char:FindFirstChildOfClass("Humanoid").Health <= 0 then continue end
                        local Vec, OnScreen = Camera2:WorldToViewportPoint(char[ss.LockPart].Position)
                        local MousePos = UserInputService:GetMouseLocation()
                        local Dist = (Vector2.new(MousePos.X, MousePos.Y) - Vector2.new(Vec.X, Vec.Y)).Magnitude
                        if Dist < ReqDist and OnScreen then
                            ReqDist = Dist
                            AimbotEnv.Locked = v
                        end
                    end
                end
            end
        else
            local char = AimbotEnv.Locked.Character
            if not char or not char:FindFirstChild(ss.LockPart) then CancelLock2(); return end
            local Vec = Camera2:WorldToViewportPoint(char[ss.LockPart].Position)
            local MousePos = UserInputService:GetMouseLocation()
            if (Vector2.new(MousePos.X, MousePos.Y) - Vector2.new(Vec.X, Vec.Y)).Magnitude > ReqDist then
                CancelLock2()
            end
        end
    end

    AimbotConns.Typing1 = UserInputService.TextBoxFocused:Connect(function() Typing2 = true end)
    AimbotConns.Typing2 = UserInputService.TextBoxFocusReleased:Connect(function() Typing2 = false end)

    AimbotConns.Render = RunService.RenderStepped:Connect(function()
        local fs = AimbotEnv.FOVSettings
        local ss = AimbotEnv.Settings
        Camera2 = workspace.CurrentCamera

        if fs.Enabled and ss.Enabled and AimbotRunning then
            AimbotEnv.FOVCircle.Radius      = fs.Amount
            AimbotEnv.FOVCircle.Thickness   = fs.Thickness
            AimbotEnv.FOVCircle.Filled      = fs.Filled
            AimbotEnv.FOVCircle.NumSides    = fs.Sides
            AimbotEnv.FOVCircle.Color       = AimbotEnv.Locked and fs.LockedColor or fs.Color
            AimbotEnv.FOVCircle.Transparency = fs.Transparency
            AimbotEnv.FOVCircle.Visible     = fs.Visible
            local mp = UserInputService:GetMouseLocation()
            AimbotEnv.FOVCircle.Position    = Vector2.new(mp.X, mp.Y)
        else
            AimbotEnv.FOVCircle.Visible = false
        end

        if Running2 and ss.Enabled and AimbotRunning then
            GetClosest2()
            if AimbotEnv.Locked then
                local char = AimbotEnv.Locked.Character
                if char and char:FindFirstChild(ss.LockPart) then
                    if ss.ThirdPerson then
                        local sens = math.clamp(ss.ThirdPersonSensitivity, 0.1, 5)
                        local Vec  = Camera2:WorldToViewportPoint(char[ss.LockPart].Position)
                        local mp2  = UserInputService:GetMouseLocation()
                        local mr   = mousemoverel or (Input and Input.MouseMove)
                        if mr then mr((Vec.X - mp2.X)*sens, (Vec.Y - mp2.Y)*sens) end
                    else
                        if ss.Sensitivity > 0 then
                            Animation2 = TweenService:Create(Camera2, TweenInfo.new(ss.Sensitivity, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {CFrame = CFrame.new(Camera2.CFrame.Position, char[ss.LockPart].Position)})
                            Animation2:Play()
                        else
                            Camera2.CFrame = CFrame.new(Camera2.CFrame.Position, char[ss.LockPart].Position)
                        end
                    end
                end
            end
        end
    end)

    AimbotConns.InputBegan = UserInputService.InputBegan:Connect(function(inp)
        if Typing2 or not AimbotRunning then return end
        local ss = AimbotEnv.Settings
        pcall(function()
            if inp.UserInputType == Enum.UserInputType[ss.TriggerKey] then
                if ss.Toggle then Running2 = not Running2; if not Running2 then CancelLock2() end
                else Running2 = true end
            end
        end)
        pcall(function()
            if inp.KeyCode == Enum.KeyCode[ss.TriggerKey] then
                if ss.Toggle then Running2 = not Running2; if not Running2 then CancelLock2() end
                else Running2 = true end
            end
        end)
    end)

    AimbotConns.InputEnded = UserInputService.InputEnded:Connect(function(inp)
        if Typing2 or not AimbotRunning or AimbotEnv.Settings.Toggle then return end
        pcall(function()
            if inp.UserInputType == Enum.UserInputType[AimbotEnv.Settings.TriggerKey] then
                Running2 = false; CancelLock2()
            end
        end)
        pcall(function()
            if inp.KeyCode == Enum.KeyCode[AimbotEnv.Settings.TriggerKey] then
                Running2 = false; CancelLock2()
            end
        end)
    end)
end

local function UnloadAimbot()
    for _, c in pairs(AimbotConns) do c:Disconnect() end
    AimbotConns = {}
    if AimbotEnv.FOVCircle then
        AimbotEnv.FOVCircle.Visible = false
        pcall(function() AimbotEnv.FOVCircle:Remove() end)
        AimbotEnv.FOVCircle = nil
    end
    AimbotLoaded = false
end

